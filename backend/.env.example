MEETING_ID=meeting_001

OPENAI_API_KEY=replace_me
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_REALTIME_WEBSOCKET_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_REASONING_EFFORT=low
OPENAI_REALTIME_OUTPUT_SAMPLE_RATE=24000

SONIOX_API_KEY=replace_me
SONIOX_WEBSOCKET_URL=wss://stt-rt.soniox.com/transcribe-websocket
SONIOX_MODEL=stt-rt-v5
SONIOX_LANGUAGE_HINTS=ja
SONIOX_ENABLE_SPEAKER_DIARIZATION=true
SONIOX_ENABLE_ENDPOINT_DETECTION=true
SONIOX_MAX_ENDPOINT_DELAY_MS=1000

AUDIO_FORMAT=pcm_s16le
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FRAME_MS=100
# Optional. Use a sounddevice input device index or name.
# AUDIO_INPUT_DEVICE=
